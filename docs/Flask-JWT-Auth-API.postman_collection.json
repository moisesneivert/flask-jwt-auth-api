{
  "info": {
    "name": "Flask JWT Authentication API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Moisés Neivert\",\n  \"email\": \"moises@example.com\",\n  \"password\": \"SecurePass1!\"\n}"
        },
        "url": "{{base_url}}/api/v1/auth/register"
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json().data;",
              "pm.collectionVariables.set('access_token', data.access_token);",
              "pm.collectionVariables.set('refresh_token', data.refresh_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"moises@example.com\",\n  \"password\": \"SecurePass1!\"\n}"
        },
        "url": "{{base_url}}/api/v1/auth/login"
      }
    },
    {
      "name": "Current user",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": "{{base_url}}/api/v1/users/me"
      }
    },
    {
      "name": "Refresh token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{refresh_token}}"
          }
        ],
        "url": "{{base_url}}/api/v1/auth/refresh"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json().data;",
              "pm.collectionVariables.set('access_token', data.access_token);",
              "pm.collectionVariables.set('refresh_token', data.refresh_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": "{{base_url}}/api/v1/auth/logout"
      }
    }
  ]
}
